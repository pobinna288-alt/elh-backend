# ==========================================
# HIGH-PERFORMANCE BACKEND CONFIGURATION
# ==========================================

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_secure_password_here
DB_DATABASE=elh_backend

# ==========================================
# REDIS (Caching & Queue)
# ==========================================
# Redis URL (full connection string)
REDIS_URL=redis://localhost:6379

# Or individual Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=development
API_PREFIX=api/v1
PORT=3000

# ==========================================
# SECURITY
# ==========================================
# JWT Configuration
JWT_SECRET=generate_a_very_long_random_string_here_min_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# API Key (for internal service-to-service communication)
API_KEY=generate_another_secure_random_key_here

# ==========================================
# RATE LIMITING
# ==========================================
# Time window in seconds
THROTTLE_TTL=60

# Maximum requests per time window
THROTTLE_LIMIT=100

# ==========================================
# PAYSTACK PAYMENT GATEWAY
# ==========================================
# Test Keys (for development)
PAYSTACK_SECRET_KEY=sk_test_your_test_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_test_public_key_here

# Production Keys (uncomment for production)
# PAYSTACK_SECRET_KEY=sk_live_your_live_secret_key_here
# PAYSTACK_PUBLIC_KEY=pk_live_your_live_public_key_here

# Payment Callback URL
PAYSTACK_CALLBACK_URL=http://localhost:3000/api/v1/payments/callback

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL=http://localhost:5500

# ==========================================
# FILE UPLOAD
# ==========================================
# Maximum file size (in bytes)
# Default: 10MB = 10 * 1024 * 1024
MAX_FILE_SIZE=10485760

# Upload directory
UPLOAD_DIR=./uploads

# ==========================================
# PERFORMANCE & MONITORING
# ==========================================
# Log level (development: debug, production: info)
LOG_LEVEL=debug

# Enable query logging (set to false in production)
ENABLE_QUERY_LOGGING=true

# Slow query threshold (milliseconds)
SLOW_QUERY_THRESHOLD=100

# ==========================================
# FRAUD DETECTION
# ==========================================
# Python service URL (if using microservice)
FRAUD_DETECTION_URL=http://localhost:8000

# ==========================================
# MARKET INTELLIGENCE (ENTERPRISE)
# ==========================================
GOOGLE_TRENDS_API_URL=
GOOGLE_TRENDS_API_KEY=
EBAY_MARKET_API_URL=
EBAY_MARKET_API_KEY=
AMAZON_PRODUCT_API_URL=
AMAZON_PRODUCT_API_KEY=

# Stability + cost control
ALLOW_KEYLESS_MARKET_APIS=false
MARKET_CACHE_TTL_TRENDS_MIN=20
MARKET_CACHE_TTL_EBAY_MIN=30
MARKET_CACHE_TTL_AMAZON_MIN=30
MARKET_COST_TRENDS=0.002
MARKET_COST_EBAY=0.004
MARKET_COST_AMAZON=0.004

# CloseFlow safety limits
CLOSEFLOW_MAX_CALLS_PER_USER_PER_DAY=20
CLOSEFLOW_CONCURRENCY_PER_USER=1

# ==========================================
# EMAIL (Optional - for notifications)
# ==========================================
# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-specific-password
# SMTP_FROM=noreply@yourdomain.com

# ==========================================
# NOTES
# ==========================================
# 1. Never commit this file to version control
# 2. Use different values for production
# 3. Generate secure random strings for secrets
# 4. Keep Paystack keys secure
# 5. Use environment-specific values

# ==========================================
# GENERATE SECURE KEYS
# ==========================================
# For JWT_SECRET and API_KEY, generate random strings:
# 
# Node.js:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# OpenSSL:
#   openssl rand -hex 32
#
# PowerShell:
#   -join ((48..57) + (65..90) + (97..122) | Get-Random -Count 32 | % {[char]$_})
