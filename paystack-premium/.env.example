# ============================================================================
# PAYSTACK PREMIUM PAYMENT SERVER - ENVIRONMENT VARIABLES
# ============================================================================
#
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control (it's in .gitignore)
#

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Server port (default: 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=development

# CORS allowed origins (use your frontend URL in production)
# Examples:
#   - http://localhost:4200 (Angular)
#   - http://localhost:3000 (React)
#   - * (allow all - for development only)
CORS_ORIGIN=*

# ============================================================================
# PAYSTACK CONFIGURATION
# ============================================================================

# Paystack Secret Key
# Get your keys from: https://dashboard.paystack.com/#/settings/developer
#
# For Testing (Development):
#   Use test key: sk_test_xxxxxxxxxxxxx
#
# For Production:
#   Use live key: sk_live_xxxxxxxxxxxxx
#
# IMPORTANT: Keep this secret! Never expose it to frontend or commit to git
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Paystack callback URL (where users are redirected after payment)
PAYSTACK_CALLBACK_URL=http://localhost:3000/payment-callback

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Use MongoDB? (true/false)
# Set to false to use in-memory mock database (good for testing)
# Set to true to use MongoDB (recommended for production)
USE_MONGODB=false

# MongoDB connection URI (only needed if USE_MONGODB=true)
# Format: mongodb://username:password@host:port/database
# Examples:
#   - Local: mongodb://localhost:27017/paystack-premium
#   - MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb://localhost:27017/paystack-premium

# MongoDB database name
MONGODB_DATABASE=paystack-premium

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Test Cards (for Paystack Test Mode):
#    - Success: 5531886652142950 | 09/32 | 564
#    - Failure: 5060666666666666666 | 09/32 | 123
#
# 2. Always use test keys during development
#
# 3. Before deploying to production:
#    - Replace test keys with live keys
#    - Enable HTTPS
#    - Set proper CORS_ORIGIN
#    - Use real database (set USE_MONGODB=true)
#
# 4. Security:
#    - Never commit .env file
#    - Never expose secret keys
#    - Always verify payments on backend
#
