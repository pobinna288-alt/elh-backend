# Environment
NODE_ENV=development

# Server
PORT=3000
API_PREFIX=api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=elh_ads_platform

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=30d

# ─── Email OTP Authentication ────────────────────────────────────────────────
# Secret used for HMAC-SHA256 OTP hashing (MUST differ from JWT_SECRET in prod)
EMAIL_OTP_SECRET=change-this-to-a-strong-random-secret-min-32-chars

# SQLite path for email OTP store (defaults to data/email-otp.sqlite)
# EMAIL_OTP_DB_PATH=data/email-otp.sqlite

# Rate limit: max OTP requests per email per window (default 3 per 10 min)
EMAIL_OTP_MAX_PER_EMAIL=3
EMAIL_OTP_WINDOW_MINUTES=10

# Rate limit: max OTP requests per IP per 24 h (default 10)
EMAIL_OTP_MAX_PER_IP_DAY=10

# OTP expiry window in minutes (default 10, max recommended 10)
EMAIL_OTP_EXPIRY_MINUTES=10

# Max invalid verification attempts before temporary block (default 5)
EMAIL_OTP_MAX_ATTEMPTS=5

# Temporary block duration in minutes after limit is exceeded (default 15)
EMAIL_OTP_BLOCK_MINUTES=15

# Set to "true" to include raw OTP in API response (development only)
RETURN_TEST_OTP=true

# ─── SMTP email delivery (requires: npm install nodemailer) ──────────────────
# Leave SMTP_HOST blank to use console logging in development
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password

# Sender identity
EMAIL_FROM=noreply@elhannora.com
EMAIL_FROM_NAME=El Hannora

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Subscription Plans (internal keys: premium=Starter, pro=Pro, hot=Elite)
PREMIUM_PRICE_USD=20
PREMIUM_PRICE_NGN=15000
PREMIUM_COINS=20000
PREMIUM_DURATION_DAYS=30
PRO_PRICE_USD=60
PRO_PRICE_NGN=45000
PRO_COINS=60000
PRO_DURATION_DAYS=30
HOT_PRICE_USD=120
HOT_PRICE_NGN=90000
HOT_COINS=120000
HOT_DURATION_DAYS=30

# Currency conversion (optional - live USD rates with fallback)
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD
EXCHANGE_RATE_CACHE_TTL_MS=3600000
EXCHANGE_RATE_TIMEOUT_MS=5000

# Python Microservice
PYTHON_SERVICE_URL=http://localhost:8000

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5500

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Phone OTP Authentication
OTP_PROVIDER=console
OTP_SENDER_NAME=ELH
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_PER_PHONE_PER_HOUR=3
OTP_MAX_PER_IP_PER_HOUR=5
TRUST_DEVICE_EXPIRY_DAYS=30
RETURN_TEST_OTP=true
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com/api/sms/send

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIRECTORY=./uploads

# Email (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Cloudinary (optional - for media storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Market Intelligence APIs (required for Enterprise market-first pipeline)
GOOGLE_TRENDS_API_URL=
GOOGLE_TRENDS_API_KEY=
EBAY_MARKET_API_URL=
EBAY_MARKET_API_KEY=
AMAZON_PRODUCT_API_URL=
AMAZON_PRODUCT_API_KEY=

# Market Intelligence stability controls
ALLOW_KEYLESS_MARKET_APIS=false
MARKET_CACHE_TTL_TRENDS_MIN=20
MARKET_CACHE_TTL_EBAY_MIN=30
MARKET_CACHE_TTL_AMAZON_MIN=30
MARKET_COST_TRENDS=0.002
MARKET_COST_EBAY=0.004
MARKET_COST_AMAZON=0.004

# CloseFlow safety limits
CLOSEFLOW_MAX_CALLS_PER_USER_PER_DAY=20
CLOSEFLOW_CONCURRENCY_PER_USER=1
